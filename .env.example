# ==========================================
# ZIGMA HUB — Environment Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ==========================================

# ----- App -----
SECRET_KEY_BASE=REPLACE_WITH_64_CHAR_RANDOM_STRING
FRONTEND_URL=https://hub.zigmaneural.com
FORCE_SSL=true
ENABLE_ACCOUNT_SIGNUP=false

# ----- Database -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=zigma_hub_production
POSTGRES_USERNAME=zigma_hub
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ----- Redis -----
REDIS_URL=redis://:REPLACE_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=REPLACE_REDIS_PASSWORD

# ----- Email (SMTP) -----
MAILER_SENDER_EMAIL=hub@zigmaneural.com
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=REPLACE_WITH_EMAIL
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# ----- Storage -----
ACTIVE_STORAGE_SERVICE=local
# For S3 (recommended for production):
# ACTIVE_STORAGE_SERVICE=amazon
# S3_BUCKET_NAME=zigma-hub-storage
# AWS_ACCESS_KEY_ID=REPLACE
# AWS_SECRET_ACCESS_KEY=REPLACE
# AWS_REGION=ap-south-1

# ----- AI — Zigma Assistant (Claude) -----
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY

# ----- SSO / SAML -----
# SAML_CERT=REPLACE
# SAML_PRIVATE_KEY=REPLACE
# SAML_IDP_METADATA_URL=https://accounts.google.com/o/saml2/...

# ----- Integrations -----
# Slack webhook for ticket notifications
SLACK_WEBHOOK_URL=REPLACE_WITH_SLACK_WEBHOOK

# Jitsi Meet (video calls)
JITSI_DOMAIN=meet.jit.si

# ----- Branding -----
APP_NAME=Zigma Hub
